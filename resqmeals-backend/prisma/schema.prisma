generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   // "DONOR", "NGO", "ADMIN"
  address    String?
  phone      String?
  darpanId   String?  // For NGO verification
  isVerified      Boolean  @default(false)
  verificationMethod String? // "EMAIL", "PHONE"
  latitude        Float?
  longitude       Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  donations Donation[] // if Donor
  requests  Request[]  // if NGO
  otps      Otp[]
}

model Donation {
  id          String   @id @default(uuid())
  foodType    String
  quantity    String
  expiry      String
  location    String
  latitude    Float?
  longitude   Float?
  status      String   @default("Pending") // "Pending", "Accepted", "Picked", "Delivered"
  currentLat  Float?   // Live tracking of carrier
  currentLng  Float?   // Live tracking of carrier
  pickupOtp   String?  // OTP generated for pickup
  searchRadius Int      @default(5) // Max distance in KM to notify NGOs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  donorId     String
  donor       User     @relation(fields: [donorId], references: [id])
  requests    Request[]
}

model Otp {
  id        String   @id @default(uuid())
  email     String?
  phone     String?
  code      String   // Hashed / encrypted code for security
  type      String   // "VERIFICATION", "PICKUP"
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
}

model Request {
  id          String   @id @default(uuid())
  donationId  String
  ngoId       String
  status      String   @default("Pending") // "Pending", "Approved", "Rejected"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  donation    Donation @relation(fields: [donationId], references: [id])
  ngo         User     @relation(fields: [ngoId], references: [id])
}

model Ngo {
  id        String   @id @default(uuid())
  name      String
  address   String?
  city      String?
  phone     String?
  email     String?
  website   String?
  latitude  Float?
  longitude Float?
  source    String?
  createdAt DateTime @default(now())

  @@map("ngos") // Mapping to the table created by the pipeline
}
